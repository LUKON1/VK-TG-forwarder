# VK User Token (obtained via Implicit Flow, refresh periodically)
VK_USER_TOKEN=your_vk_user_token

# VK peer_id of the target conversation (2000000000 + chat_id)
VK_PEER_ID=2000000001

# Telegram Bot Token from @BotFather
TG_BOT_TOKEN=your_telegram_bot_token

# Telegram target chat/group ID (negative for groups, e.g. -1001234567890)
TG_CHAT_ID=-1001234567890
