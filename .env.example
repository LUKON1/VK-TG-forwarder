# VK Community Token
# Get from: vk.com/[community] → Manage → Extra → API → Create key (check "Messages")
VK_COMMUNITY_TOKEN=your_community_token_here

# VK peer_id of the target conversation (from URL: vk.com/im/convo/2000000007 → 2000000007)
VK_PEER_ID=2000000007

# Telegram Bot Token from @BotFather
TG_BOT_TOKEN=your_telegram_bot_token

# Telegram target group ID (negative number, e.g. -1001234567890)
TG_CHAT_ID=-1001234567890
