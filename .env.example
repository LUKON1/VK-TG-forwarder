# VK Community Token (from community admin panel → Extra → API → Create key)
VK_COMMUNITY_TOKEN=your_community_token_here

# Routing: one or more VK peer → Telegram chat ID pairs (JSON array)
# vk: peer_id from VK conversation URL (vk.com/im/convo/2000000007 → 2000000007)
# tg: Telegram group ID (negative number, get via @userinfobot)
ROUTES=[{"vk":2000000007,"tg":-1001234567890}]

# Telegram Bot Token from @BotFather
TG_BOT_TOKEN=your_telegram_bot_token
